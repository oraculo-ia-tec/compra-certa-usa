# Copie os valores reais para o painel de Secrets do Streamlit Cloud
# (ou para .streamlit/secrets.toml em execucao local com Streamlit).
# NUNCA commitar o arquivo secrets.toml com valores reais.

[default]
DATABASE_URL = ""
APP_BASE_URL = "https://compra-certa-usa.streamlit.app"
ADMIN_PASSWORD = "troque_esta_senha"

# Conta oraculosia
GROQ_API_KEY = ""

[email]
# ---- E-mail SMTP (Hostinger) ----
EMAIL_HOST = "smtp.hostinger.com"
EMAIL_PORT = "587"
EMAIL_USERNAME = "contato@oraculosia.site"
EMAIL_PASSWORD = ""
EMAIL_USE_TLS = "true"
EMAIL_USE_SSL = "false"
EMAIL_REMETENTE = "contato@oraculosia.site"

# ===== CHAVE E AMBIENTE STRIPE =====

#STRIPE_API_KEY=""

