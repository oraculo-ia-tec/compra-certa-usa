# ===== COMPRA CERTA USA - Variaveis de ambiente (uso local) =====
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o arquivo .env com valores reais.

DATABASE_URL=sqlite:///compra_certa_usa.db
APP_BASE_URL=http://localhost:8501
ADMIN_PASSWORD=troque_esta_senha

# Conta oraculosia
GROQ_API_KEY=

# ---- E-mail SMTP (Hostinger) ----
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=contato@oraculosia.site
EMAIL_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_REMETENTE=contato@oraculosia.site

# ===== STRIPE (assinaturas) =====
# Use suas chaves do painel: https://dashboard.stripe.com/test/apikeys
# NUNCA commitar as chaves reais aqui.

STRIPE_API_KEY=sk_test_SUA_CHAVE_SECRETA_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_SUA_CHAVE_PUBLICA_AQUI

# Price IDs dos planos Compra Certa USA (modo teste)
STRIPE_PRICE_STARTER=price_1TpvRpEULDZItXx8pvTFhTjp
STRIPE_PRICE_PRO=price_1TpvRpEULDZItXx8eNi2m9J2
STRIPE_PRICE_PREMIUM=price_1TpvRqEULDZItXx8Q0zDKfBt

# ===== CONFIGURAÇÃO DE API =====
STRIPE_API_VERSION=2024-06-20
STRIPE_TIMEOUT=10
STRIPE_MAX_RETRIES=2
